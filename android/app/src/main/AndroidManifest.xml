<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- android:networkSecurityConfig below is manually added (not part of the
         default Capacitor template) — points at res/xml/network_security_config.xml
         to allow cleartext HTTP to the LAN server. -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/AppTheme">
        <!-- Runtime-switchable launcher icon/name (activity-alias pattern, same
             technique used by WhatsApp/Instagram) — see IconSwitcher.java.

             NOTE: the real activity below is intentionally left android:enabled="true"
             (not "false" as it might seem it should be). Disabling the concrete
             target Activity component breaks alias-based launching on several
             Android versions/OEM launchers — PackageManager tracks the alias's
             own enabled state separately, but still validates the underlying
             target activity's enabled state when actually starting it, so a
             disabled target can throw ActivityNotFoundException even via an
             enabled alias. Hiding it from the launcher is already achieved by
             moving the MAIN/LAUNCHER intent-filter onto the aliases below —
             the real activity has no launcher entry-point of its own, so users
             can't launch it directly regardless of its enabled state. -->
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:enabled="true"
            android:exported="true" />

        <!-- One alias per icon/name variant. Only one may be enabled at a time
             (see IconSwitcher.setAppIconAndName) — the default one starts enabled
             so the app has a launcher entry on first install. -->
        <activity-alias
            android:name=".IconDefault"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:label="@string/app_name_default"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".IconAlt1"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_alt1"
            android:roundIcon="@mipmap/ic_launcher_alt1"
            android:label="@string/app_name_alt1"
            android:enabled="false"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".IconAlt2"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_alt2"
            android:roundIcon="@mipmap/ic_launcher_alt2"
            android:label="@string/app_name_alt2"
            android:enabled="false"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Camera-based barcode scanning (Scan barcode button on New Order) — uses
         the WebView's standard getUserMedia prompt, not a native camera API. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
</manifest>

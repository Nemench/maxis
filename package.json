{
  "name": "maxis-kot",
  "version": "1.0.0",
  "description": "KOT system for Maxis Discount Kosher Butchery.",
  "type": "module",
  "main": "electron-dist/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsx watch server/index.ts\"",
    "build": "vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "lint": "eslint .",
    "build:win": "npm run build && npx tsup && npx electron-builder --win --publish never",
    "electron:preview": "npm run build && npx tsup && npx electron ."
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.6.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@eslint/js": "^9.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "com.nemench.maxis",
    "productName": "MAXIS KOT",
    "npmRebuild": false,
    "files": [
      "electron-dist/**",
      "server-dist/**",
      "dist/**",
      "node_modules/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/bindings/**",
      "node_modules/file-uri-to-path/**"
    ],
    "extraResources": [
      {
        "from": "public/logo.jpg",
        "to": "logo.jpg"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo.jpg"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "directories": {
      "output": "release",
      "buildResources": "public"
    }
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "esbuild@0.27.7": true,
    "esbuild@0.28.1": true,
    "better-sqlite3@9.6.0": true
  }
}
